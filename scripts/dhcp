#!/bin/bash

source /usr/local/JSBach/conf/variables.conf

CONF_FILE="/etc/dnsmasq.conf"
BACKUP_FILE="/etc/dnsmasq.conf.bak"

# Funcio per validar format IPv4
validate_ipv4() {
    local ip=$1
    if [[ $ip =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
        return 0
    else
        return 1
    fi
}

# Funcio per validar que la IP pertany a la subred de la VLAN (/24)
validate_subnet() {
    local ip=$1
    local vlan=$2
    local subnet_prefix=""

    case "$vlan" in
        "br0.1") subnet_prefix="10.0.1" ;;
        "br0.2") subnet_prefix="10.0.2" ;;
        "br0.3") subnet_prefix="10.0.3" ;;
        "br0.4") subnet_prefix="10.0.4" ;;
        *) return 1 ;;
    esac

    if [[ $ip == $subnet_prefix.* ]]; then
        return 0
    else
        return 1
    fi
}

fnc_estat() {
    echo "<h2>dnsmasq status:</h2>"
    echo "<pre>"
    systemctl status dnsmasq | head -n 10
    echo "</pre>"
    echo "<h2>Habilitat a l'arrencada:</h2>"
    echo "<pre>"
    systemctl is-enabled dnsmasq
    echo "</pre>"
}

fnc_iniciar() {
    echo "Habilitant dnsmasq per a l'arrencada..."
    systemctl enable dnsmasq
    echo "Iniciant el servei dnsmasq..."
    systemctl start dnsmasq
    echo "Servei iniciat."
}


fnc_reiniciar() {
    echo "Reiniciant el servei dnsmasq..."
    systemctl restart dnsmasq
    echo "Servei reiniciat."
}

fnc_aturar() {
    echo "Aturant el servei dnsmasq..."
    systemctl stop dnsmasq
    echo "Deshabilitant dnsmasq de l'arrencada..."
    systemctl disable dnsmasq
    echo "Servei aturat."
}

fnc_consultar() {
    local vlan=$1
    # dhcp-range=10.0.1.50,10.0.1.100,255.255.255.0,12h
    local line_range=$(grep "interface=$vlan" -A 1 "$CONF_FILE" | grep "dhcp-range")
    local range_ini=$(echo "$line_range" | cut -d',' -f1 | cut -d'=' -f2)
    local range_fi=$(echo "$line_range" | cut -d',' -f2)
    local lease=$(echo "$line_range" | cut -d',' -f4)
    
    # dhcp-option=interface:br0.1,option:router,10.0.1.1
    local gw=$(grep "interface:$vlan,option:router" "$CONF_FILE" | cut -d',' -f3)
    local dns=$(grep "interface:$vlan,option:dns-server" "$CONF_FILE" | cut -d',' -f3)

    echo "$range_ini $range_fi $lease $gw $dns"
}

fnc_configurar() {
    local vlan=$1
    local r_ini=$2
    local r_fi=$3
    local lease=$4
    local gw=$5
    local dns=$6

    # Validacions
    for ip in "$r_ini" "$r_fi" "$gw" "$dns"; do
        if ! validate_ipv4 "$ip"; then
            echo "ERROR: Format IP invalid: $ip"
            return 1
        fi
        if ! validate_subnet "$ip" "$vlan"; then
            echo "ERROR: L'IP $ip no pertany a la subred de $vlan"
            return 1
        fi
    done

    # Backup
    cp "$CONF_FILE" "$BACKUP_FILE"

    # Modificar configuració
    # dhcp-range
    sed -i "/interface=$vlan/{n;s|dhcp-range=.*|dhcp-range=$r_ini,$r_fi,255.255.255.0,$lease|}" "$CONF_FILE"
    # dhcp-option router
    sed -i "s|dhcp-option=interface:$vlan,option:router,.*|dhcp-option=interface:$vlan,option:router,$gw|" "$CONF_FILE"
    # dhcp-option dns-server
    sed -i "s|dhcp-option=interface:$vlan,option:dns-server,.*|dhcp-option=interface:$vlan,option:dns-server,$dns|" "$CONF_FILE"

    # Test sintaxi
    if dnsmasq --test > /dev/null 2>&1; then
        systemctl restart dnsmasq
        return 0
    else
        echo "ERROR: Sintaxi de dnsmasq incorrecta. Restaurat backup."
        cp "$BACKUP_FILE" "$CONF_FILE"
        return 1
    fi
}

fnc_restaurar() {
    if [ -f "$BACKUP_FILE" ]; then
        cp "$BACKUP_FILE" "$CONF_FILE"
        systemctl restart dnsmasq
        return 0
    else
        return 1
    fi
}

case "$1" in
    estat) fnc_estat ;;
    iniciar) fnc_iniciar ;;
    reiniciar) fnc_reiniciar;;
    aturar) fnc_aturar ;;
    consultar) fnc_consultar "$2" ;;
    configurar) fnc_configurar "$2" "$3" "$4" "$5" "$6" "$7" ;;
    restaurar) fnc_restaurar ;;
    *) echo "Usage: $0 {iniciar|reiniciar|aturar|consultar|configurar|restaurar}" ;;
esac
