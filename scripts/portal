#!/bin/bash

source /usr/local/JSBach/conf/variables.conf
source /usr/local/JSBach/conf/portal.conf

SESSION_DIR=/usr/local/JSBach/run/portal/sessions
mkdir -p "$SESSION_DIR"
chmod 777 "$SESSION_DIR"
mkdir -p /usr/local/JSBach/run/portal/failed_attempts
chmod 777 /usr/local/JSBach/run/portal/failed_attempts

# Detectar nombre de interfaz de VLAN
get_vlan_if() {
    local vid=$1
    if ip addr show "br0.$vid" >/dev/null 2>&1; then
        echo "br0.$vid"
    elif ip addr show "vlan$vid" >/dev/null 2>&1; then
        echo "vlan$vid"
    else
        # Fallback experimental o error
        echo "br0.$vid"
    fi
}

fnc_iniciar() {
    if [ "$ENABLED" -ne 1 ] && [ "$ENABLED" != "1" ]; then
        echo "Portal deshabilitado en la configuración (ENABLED=$ENABLED)."
        return
    fi

    if [ -z "$VLAN_VID" ]; then
        echo "Error: VLAN_VID no definida."
        return
    fi

    local IF_VLAN=$(get_vlan_if "$VLAN_VID")

    # Obtener nombre de la VLAN y la IP de la puerta de enlace (campo 4 en bridge.conf)
    linia=$(grep ";$VLAN_VID;" "$DIR/$PROJECTE/$DIR_CONF/$BRIDGE_CONF")
    VLAN_NAME=$(echo "$linia" | cut -d';' -f1)
    # El campo 3 es la red, el campo 4 es la IP de la interfaz (pasarela)
    VLAN_IP=$(echo "$linia" | cut -d';' -f4 | cut -d'/' -f1)

    if [ -z "$VLAN_NAME" ] || [ -z "$VLAN_IP" ]; then
        echo "Error: No se encontró la VLAN $VLAN_VID o su IP de pasarela."
        return
    fi

    echo "Iniciando Portal Cautivo para $VLAN_NAME ($VLAN_IP) en interfaz $IF_VLAN"

    # Crear chains si no existen
    iptables -N PORTAL_AUTH 2>/dev/null
    iptables -t nat -N PORTAL_REDIRECT 2>/dev/null

    # Limpiar chains
    iptables -F PORTAL_AUTH
    iptables -t nat -F PORTAL_REDIRECT

    # Redirección HTTP hacia el portal
    SERVER_IP="$VLAN_IP"
    
    # Capturar tráfico puerto 80 (HTTP)
    # Redirigimos solo el puerto 80. El puerto 443 NO se redirige para evitar errores SSL/HSTS
    # que bloquean la detección de conectividad en clientes modernos.
    iptables -t nat -A PREROUTING -i "$IF_VLAN" -p tcp --dport 80 -j PORTAL_REDIRECT
    
    # Excluir el propio servidor y Walled Garden
    iptables -t nat -A PORTAL_REDIRECT -d "$SERVER_IP" -j RETURN
    
    # Walled Garden
    for item in $(echo "$WALLED_GARDEN" | tr ',' ' '); do
        iptables -t nat -A PORTAL_REDIRECT -d "$item" -j RETURN
    done

    # IMPORTANTE: Los usuarios ya autenticados deben saltarse la redirección
    iptables -t nat -A PORTAL_REDIRECT -m mark --mark 0x1 -j RETURN

    # Redirigir el resto al servidor local (Puerto 80 para el portal)
    iptables -t nat -A PORTAL_REDIRECT -p tcp --dport 80 -j DNAT --to-destination "$SERVER_IP:80"

    # En el FORWARD, marcar paquetes de usuarios autenticados y permitir el paso
    iptables -D FORWARD -i "$IF_VLAN" -j PORTAL_AUTH 2>/dev/null
    iptables -I FORWARD -i "$IF_VLAN" -j PORTAL_AUTH
    
    # Regla para marcar paquetes de usuarios ya autorizados (para que se salten el NAT de arriba)
    iptables -A PORTAL_AUTH -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
    
    # Permitir DNS y DHCP siempre
    iptables -A PORTAL_AUTH -p udp --dport 53 -j ACCEPT
    iptables -A PORTAL_AUTH -p udp --dport 67:68 -j ACCEPT
    
    # El resto se dropea (las sesiones autenticadas se insertarán al principio como ACCEPT + MARK)
    iptables -A PORTAL_AUTH -j DROP
}

fnc_aturar() {
    echo "Deteniendo Portal Cautivo para VLAN $VLAN_VID"
    local IF_VLAN=$(get_vlan_if "$VLAN_VID")
    
    # Eliminar saltos a PORTAL_AUTH
    iptables -D FORWARD -i "$IF_VLAN" -j PORTAL_AUTH 2>/dev/null
    
    # Limpiar y eliminar PREROUTING jumps específicos
    iptables -t nat -D PREROUTING -i "$IF_VLAN" -p tcp --dport 80 -j PORTAL_REDIRECT 2>/dev/null
    iptables -t nat -D PREROUTING -i "$IF_VLAN" -p tcp --dport 443 -j PORTAL_REDIRECT 2>/dev/null

    # Limpiar y eliminar chains
    iptables -t nat -F PORTAL_REDIRECT 2>/dev/null
    iptables -t nat -X PORTAL_REDIRECT 2>/dev/null
    iptables -F PORTAL_AUTH 2>/dev/null
    iptables -X PORTAL_AUTH 2>/dev/null
}

fnc_estat() {
    echo "=== Estado del Portal Cautivo ==="
    echo "ENABLED: $ENABLED"
    echo "VLAN_VID: $VLAN_VID"
    local IF_VLAN=$(get_vlan_if "$VLAN_VID")
    echo "Interfaz detectada: $IF_VLAN"
    echo
    echo "--- Saltos (Jumps) ---"
    iptables -t nat -S PREROUTING | grep PORTAL_REDIRECT || echo "PREROUTING -> PORTAL_REDIRECT: FALTA"
    iptables -S FORWARD | grep PORTAL_AUTH || echo "FORWARD -> PORTAL_AUTH: FALTA"
    echo
    echo "--- Reglas NAT (Redirección) ---"
    if iptables -t nat -L PORTAL_REDIRECT -n -v >/dev/null 2>&1; then
        iptables -t nat -L PORTAL_REDIRECT -n -v
    else
        echo "Chain PORTAL_REDIRECT no existe"
    fi
    echo
    echo "--- Reglas FILTER (Autorización) ---"
    iptables -L PORTAL_AUTH -n -v 2>/dev/null || echo "Chain PORTAL_AUTH no existe"
    echo
    echo "--- Sesiones activas ---"
    ls -l "$SESSION_DIR" 2>/dev/null | grep "^-" | wc -l
}

fnc_auth_user() {
    local ip="$1"
    local mac="$2"
    local user="$3"

    if [ -z "$ip" ] || [ -z "$mac" ]; then
        echo "Error: IP y MAC requeridas."
        return
    fi

    echo "Autenticando usuario $user (IP: $ip, MAC: $mac)"

    # Añadir regla de aceptación con marca para evitar el redireccionamiento NAT
    # Usamos -I para que vaya al principio de la cadena
    iptables -I PORTAL_AUTH 1 -s "$ip" -m mac --mac-source "$mac" -j MARK --set-xmark 0x1/0xffffffff
    iptables -I PORTAL_AUTH 2 -s "$ip" -m mac --mac-source "$mac" -j ACCEPT

    # Crear archivo de sesión
    local sid=$(echo "$ip$mac$(date +%s)" | sha256sum | cut -c1-16)
    local session_file="$SESSION_DIR/$sid"
    
    cat > "$session_file" << EOF
IP="$ip"
MAC="$mac"
USER="$user"
START=$(date +%s)
LAST=$(date +%s)
EOF
    chmod 644 "$session_file"

    # Log authentication
    echo "$(date '+%Y-%m-%d %H:%M:%S') [AUTH] User: $user, IP: $ip, MAC: $mac" >> /usr/local/JSBach/logs/portal.log

    echo "$sid"
}

fnc_deauth_user() {
    local ip="$1"
    local mac="$2"

    iptables -D PORTAL_AUTH -s "$ip" -m mac --mac-source "$mac" -j MARK --set-xmark 0x1/0xffffffff 2>/dev/null
    iptables -D PORTAL_AUTH -s "$ip" -m mac --mac-source "$mac" -j ACCEPT 2>/dev/null
    
    # Eliminar archivo de sesión
    for f in "$SESSION_DIR"/*; do
        [ -f "$f" ] || continue
        if grep -q "IP=\"$ip\"" "$f" && grep -q "MAC=\"$mac\"" "$f"; then
            user_found=$(grep "USER=" "$f" | cut -d'"' -f2)
            rm -f "$f"
            # Log deauth
            echo "$(date '+%Y-%m-%d %H:%M:%S') [DEAUTH] User: $user_found, IP: $ip, MAC: $mac" >> /usr/local/JSBach/logs/portal.log
        fi
    done
}

fnc_cleanup() {
    local now=$(date +%s)
    for session in "$SESSION_DIR"/*; do
        [ -e "$session" ] || continue
        source "$session"
        local age=$((now - LAST))
        local total_age=$((now - START))

        if [ "$age" -gt "$IDLE_TIMEOUT" ] || [ "$total_age" -gt "$SESSION_TIMEOUT" ]; then
            fnc_deauth_user "$IP" "$MAC"
        fi
    done
}

fnc_configurar() {
    local enabled="$1"
    local vlan_vid="$2"
    local session_timeout="$3"
    local idle_timeout="$4"
    local walled_garden="$5"
    local welcome_text="$6"
    local primary_color="$7"

    # Obtener IP de la pasarela para esta VLAN
    local gateway=$(grep ";$vlan_vid;" "/usr/local/JSBach/conf/bridge.conf" | cut -d';' -f4 | cut -d'/' -f1)
    [ -z "$gateway" ] && gateway="10.0.3.1"

    local login_url="http://$gateway/cgi-bin/portal-login.cgi"

    # Guardar en portal.conf
    cat > "/usr/local/JSBach/conf/portal.conf" << EOF
# Portal Cautivo Configuration
ENABLED="$enabled"
VLAN_VID="$vlan_vid"
LOGIN_URL="$login_url"
SESSION_TIMEOUT="$session_timeout"
IDLE_TIMEOUT="$idle_timeout"
WALLED_GARDEN="$walled_garden"
LOGO_URL="/img/logo.png"
WELCOME_TEXT="$welcome_text"
PRIMARY_COLOR="$primary_color"
TERMS_OF_USE="Al acceder a esta red, usted acepta nuestros términos y condiciones."
FAILED_ATTEMPTS_LIMIT="5"
LOCKOUT_TIME="300"
EOF

    echo "Configuración del Portal Cautivo guardada."

    # Aplicar cambios (recargar configuración y reiniciar si es necesario)
    source /usr/local/JSBach/conf/portal.conf
    if [ "$enabled" -eq 1 ]; then
        fnc_aturar > /dev/null 2>&1
        fnc_iniciar > /dev/null 2>&1
        echo "Portal Cautivo reiniciado con la nueva configuración."
    else
        fnc_aturar > /dev/null 2>&1
        echo "Portal Cautivo detenido."
    fi
}

case "$1" in
    iniciar) fnc_iniciar ;;
    aturar) fnc_aturar ;;
    estat) fnc_estat ;;
    auth) fnc_auth_user "$2" "$3" "$4" ;;
    deauth) fnc_deauth_user "$2" "$3" ;;
    cleanup) fnc_cleanup ;;
    configurar) fnc_configurar "$2" "$3" "$4" "$5" "$6" "$7" "$8" ;;
    *) echo "Uso: $0 {iniciar|aturar|estat|auth|deauth|cleanup|configurar}" ;;
esac
